            "description": "Successful Response",
            "content": { "application/json": { "schema": {} } }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/teams/{team_name}/messages/chat": {
      "get": {
        "tags": ["messages"],
        "summary": "Get Chat Messages",
        "description": "チャット形式表示用のメッセージを取得する。\n\n指定されたチームのメッセージをチャット形式で返します。\n秘密メッセージ（DM）の判定、閲覧可能エージェントの設定を含みます。\n\nArgs:\n    team_name: チーム名\n    start_time: 開始時刻 (ISO 8601形式)\n    end_time: 終了時刻 (ISO 8601形式)\n    since: 差分更新用: 前回取得時刻 (ISO 8601形式)。指定するとこの時刻以降のメッセージのみ返却\n    senders: 送信者（カンマ区切り）\n    types: メッセージタイプ（カンマ区切り）\n    search: 検索キーワード\n    unread_only: 未読のみ取得するか\n    limit: 取得件数上限 (最大500)\n    offset: オフセット\n\nReturns:\n    チャットメッセージリスト",
        "operationId": "get_chat_messages_api_teams__team_name__messages_chat_get",
        "parameters": [
          {
