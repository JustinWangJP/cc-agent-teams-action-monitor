            "schema": { "type": "string", "title": "Team Name" }
          },
          {
            "name": "start_time",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "string" }, { "type": "null" }],
              "description": "開始時刻 (ISO 8601)",
              "title": "Start Time"
            },
            "description": "開始時刻 (ISO 8601)"
          },
          {
            "name": "end_time",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "string" }, { "type": "null" }],
              "description": "終了時刻 (ISO 8601)",
              "title": "End Time"
            },
            "description": "終了時刻 (ISO 8601)"
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "string" }, { "type": "null" }],
              "description": "差分更新用: 前回取得時刻以降のメッセージのみ取得 (ISO 8601)",
              "title": "Since"
            },
            "description": "差分更新用: 前回取得時刻以降のメッセージのみ取得 (ISO 8601)"
          },
          {
            "name": "senders",
            "in": "query",
            "required": false,
            "schema": {
