            "schema": {
              "anyOf": [{ "type": "string" }, { "type": "null" }],
              "description": "検索キーワード",
              "title": "Search"
            },
            "description": "検索キーワード"
          },
          {
            "name": "unread_only",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "未読のみ",
              "default": false,
              "title": "Unread Only"
            },
            "description": "未読のみ"
          }
        ],
        "responses": {
