{
  "openapi": "3.1.0",
  "info": {
    "title": "Agent Teams Dashboard API",
    "description": "Real-time monitoring API for Claude Code Agent Teams",
    "version": "0.1.0"
  },
  "paths": {
    "/api/teams/": {
      "get": {
        "tags": ["teams"],
        "summary": "List Teams",
        "description": "全チーム一覧を取得するエンドポイント。\n\n~/.claude/teams/ ディレクトリ内の全チームの config.json を読み込み、\nTeamSummary 形式で返します。\n\nステータス判定基準:\n- inactive: members が空\n- unknown: セッションログが存在しない\n- stopped: セッションログ mtime が1時間超過\n- active: セッションログ mtime が1時間以内\n\nReturns:\n    list[TeamSummary]: チーム概要情報のリスト",
        "operationId": "list_teams_api_teams__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": { "$ref": "#/components/schemas/TeamSummary" },
                  "type": "array",
                  "title": "Response List Teams Api Teams  Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/teams/{team_name}": {
      "get": {
        "tags": ["teams"],
        "summary": "Get Team",
        "description": "指定チームの詳細を取得するエンドポイント。\n\nチーム名を指定してチーム設定とメンバーリストを取得し、Team 形式で返します。\nチームまたは設定ファイルが存在しない場合は 404 エラーを返します。\n\nArgs:\n    team_name: 取得対象のチーム名\n\nReturns:\n    Team: チーム詳細情報\n\nRaises:\n    HTTPException: チームが存在しない場合 (404)",
        "operationId": "get_team_api_teams__team_name__get",
        "parameters": [
          {
            "name": "team_name",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "title": "Team Name" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Team" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["teams"],
        "summary": "Delete Team",
        "description": "チームを削除するエンドポイント。\n\n指定されたチームと関連ファイルを削除します。\n削除できるのは「stopped」状態のチームのみです。\n\n削除対象:\n- teams/{team_name}/ ディレクトリ\n- tasks/{team_name}/ ディレクトリ\n- projects/{project_hash}/ ディレクトリ\n\nArgs:\n    team_name: 削除対象のチーム名\n\nReturns:\n    dict: 削除結果（メッセージと削除パス一覧）\n\nRaises:\n    HTTPException:\n        - 404: チームが存在しない\n        - 400: ステータスが stopped 以外\n        - 500: 削除処理中にエラー",
        "operationId": "delete_team_api_teams__team_name__delete",
        "parameters": [
          {
            "name": "team_name",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "title": "Team Name" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": { "application/json": { "schema": {} } }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/teams/{team_name}/inboxes": {
      "get": {
        "tags": ["teams"],
        "summary": "Get Team Inboxes Api",
        "description": "チームのインボックスメッセージを取得するエンドポイント。\n\n指定されたチームの inboxes/ ディレクトリから全エージェントのメッセージを取得し、\nエージェント名をキーとする辞書形式で返します。チーム不存在時は 404 エラー。\n\nArgs:\n    team_name: チーム名\n\nReturns:\n    dict: エージェント名をキーとするメッセージリストの辞書\n\nRaises:\n    HTTPException: チームが存在しない場合 (404)",
        "operationId": "get_team_inboxes_api_api_teams__team_name__inboxes_get",
        "parameters": [
          {
            "name": "team_name",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "title": "Team Name" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": { "application/json": { "schema": {} } }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/teams/{team_name}/inboxes/{agent_name}": {
      "get": {
        "tags": ["teams"],
        "summary": "Get Agent Inbox",
        "description": "特定エージェントのインボックスメッセージを取得するエンドポイント。\n\n指定されたチーム・エージェントのインボックスファイルからメッセージを取得し、\nJSON形式で返します。チームまたはファイルが存在しない場合は404エラー。\n\nArgs:\n    team_name: チーム名\n    agent_name: エージェント名\n\nReturns:\n    エージェントのインボックスメッセージリスト",
        "operationId": "get_agent_inbox_api_teams__team_name__inboxes__agent_name__get",
        "parameters": [
          {
            "name": "team_name",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "title": "Team Name" }
          },
          {
            "name": "agent_name",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "title": "Agent Name" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": { "application/json": { "schema": {} } }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/tasks/": {
      "get": {
        "tags": ["tasks"],
        "summary": "List Tasks",
        "description": "全チームの全タスク一覧を取得するエンドポイント。\n\n~/.claude/tasks/ ディレクトリ内の全チームのタスクを読み込み、\nTaskSummary 形式で返します。チーム名も各タスクに含まれます。\n24時間以上更新のないタスクは 'stopped' ステータスに変換します。\n\nReturns:\n    list[TaskSummary]: タスク概要情報のリスト",
        "operationId": "list_tasks_api_tasks__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": { "$ref": "#/components/schemas/TaskSummary" },
                  "type": "array",
                  "title": "Response List Tasks Api Tasks  Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/tasks/team/{team_name}": {
      "get": {
        "tags": ["tasks"],
        "summary": "List Team Tasks",
        "description": "指定チームのタスク一覧を取得するエンドポイント。\n\n指定されたチーム名のタスクディレクトリから全タスクを読み込み、\nTask 形式（詳細版）で返します。チームが存在しない場合は 404 エラー。\n\nArgs:\n    team_name: 取得対象のチーム名\n\nReturns:\n    list[Task]: タスク詳細情報のリスト\n\nRaises:\n    HTTPException: チームが存在しない場合（404）",
        "operationId": "list_team_tasks_api_tasks_team__team_name__get",
        "parameters": [
          {
            "name": "team_name",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "title": "Team Name" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Task" },
                  "title": "Response List Team Tasks Api Tasks Team  Team Name  Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/tasks/{task_id}": {
      "get": {
        "tags": ["tasks"],
        "summary": "Get Task",
        "description": "特定のタスク詳細を取得するエンドポイント。\n\nタスクIDを指定してタスク詳細を取得します。team_name が指定された場合は\nそのチーム内で検索し、未指定の場合は全チームから検索します。\n\nArgs:\n    task_id: 取得対象のタスクID\n    team_name: 検索対象のチーム名（省略時は全チーム検索）\n\nReturns:\n    dict: タスク詳細データ\n\nRaises:\n    HTTPException: タスクが見つからない場合（404）",
        "operationId": "get_task_api_tasks__task_id__get",
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "title": "Task Id" }
          },
          {
            "name": "team_name",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "string" }, { "type": "null" }],
              "title": "Team Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": { "application/json": { "schema": {} } }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/models": {
      "get": {
        "tags": ["messages"],
        "summary": "Get Available Models",
        "description": "利用可能なモデル一覧と設定を取得する。\n\n各AIモデルの色、アイコン、ラベル等の設定情報を返します。\nフロントエンドでのモデル可視化に使用します。\n\nReturns:\n    モデル設定リスト",
        "operationId": "get_available_models_api_models_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ModelListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/cache/stats": {
      "get": {
        "tags": ["messages"],
        "summary": "Get Cache Stats",
        "description": "キャッシュ統計情報を取得します。\n\nキャッシュのヒット率、キャッシュ済みアイテム数などを返します。\nモニタリングやデバッグに使用します。\n\nReturns:\n    キャッシュ統計辞書",
        "operationId": "get_cache_stats_api_cache_stats_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": { "application/json": { "schema": {} } }
          }
        }
      }
    },
    "/api/teams/{team_name}/messages/timeline": {
      "get": {
        "tags": ["messages"],
        "summary": "Get Message Timeline",
        "description": "タイムライン表示用のメッセージを取得する。\n\n指定されたチームのメッセージをタイムライン形式で返します。\n時間範囲、送信者、タイプ、検索キーワードでフィルタリング可能です。\n\nArgs:\n    team_name: チーム名\n    start_time: 開始時刻 (ISO 8601形式)\n    end_time: 終了時刻 (ISO 8601形式)\n    since: 差分更新用: 前回取得時刻 (ISO 8601形式)。指定するとこの時刻以降のメッセージのみ返却\n    senders: 送信者（カンマ区切り）\n    types: メッセージタイプ（カンマ区切り）\n    search: 検索キーワード\n    unread_only: 未読のみ取得するか\n    limit: 取得件数上限 (最大500)\n    offset: オフセット\n\nReturns:\n    タイムラインデータ（アイテム、グループ、時間範囲）",
        "operationId": "get_message_timeline_api_teams__team_name__messages_timeline_get",
        "parameters": [
          {
            "name": "team_name",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "title": "Team Name" }
          },
          {
            "name": "start_time",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "string" }, { "type": "null" }],
              "description": "開始時刻 (ISO 8601)",
              "title": "Start Time"
            },
            "description": "開始時刻 (ISO 8601)"
          },
          {
            "name": "end_time",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "string" }, { "type": "null" }],
              "description": "終了時刻 (ISO 8601)",
              "title": "End Time"
            },
            "description": "終了時刻 (ISO 8601)"
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "string" }, { "type": "null" }],
              "description": "差分更新用: 前回取得時刻以降のメッセージのみ取得 (ISO 8601)",
              "title": "Since"
            },
            "description": "差分更新用: 前回取得時刻以降のメッセージのみ取得 (ISO 8601)"
          },
          {
            "name": "senders",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "string" }, { "type": "null" }],
              "description": "送信者（カンマ区切り）",
              "title": "Senders"
            },
            "description": "送信者（カンマ区切り）"
          },
          {
            "name": "types",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "string" }, { "type": "null" }],
              "description": "タイプ（カンマ区切り）",
              "title": "Types"
            },
            "description": "タイプ（カンマ区切り）"
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "string" }, { "type": "null" }],
              "description": "検索キーワード",
              "title": "Search"
            },
            "description": "検索キーワード"
          },
          {
            "name": "unread_only",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "未読のみ",
              "default": false,
              "title": "Unread Only"
            },
            "description": "未読のみ"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 500,
              "minimum": 1,
              "description": "取得件数上限",
              "default": 100,
              "title": "Limit"
            },
            "description": "取得件数上限"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "description": "オフセット",
              "default": 0,
              "title": "Offset"
            },
            "description": "オフセット"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TimelineData" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      }
    },
